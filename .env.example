# HUY COFFEE STORE - CẤU HÌNH MẪU (DÀNH CHO NGƯỜI MUỐN CHẠY DEMO)
# --------------------------------------------------------------------------
# HƯỚNG DẪN: 
# 1. Đổi tên file này thành .env
# 2. Bạn có thể giữ nguyên MONGO_URI bên dưới để xem dữ liệu mẫu (Quyền chỉ đọc)
# 3. Hoặc thay bằng link MongoDB cá nhân của bạn để toàn quyền quản lý.


# 1. Cổng chạy Server
PORT=3030

# 2. Kết nối Database (Sẵn tài khoản 'khach_xem' để Demo nhanh)
# Link này cho phép kết nối và xem 20 món cà phê trên Cloud của Huy
MONGO_URI=mongodb://khach_xem:huy_coffee_123@ac-orv0msw-shard-00-00.pr27s7r.mongodb.net:27017,ac-orv0msw-shard-00-01.pr27s7r.mongodb.net:27017,ac-orv0msw-shard-00-02.pr27s7r.mongodb.net:27017/coffee-store?ssl=true&replicaSet=atlas-u6mfva-shard-0&authSource=admin&appName=Cluster0

# 3. Mã bảo mật mẫu cho Session & JWT
JWT_SECRET=huy_uchihahuyyy_secret_key_demo
SESSION_SECRET=huy_coffee_store_session_demo

# 4. Thông tin Google/Facebook Auth (Cần điền nếu muốn dùng đăng nhập MXH)
GOOGLE_CLIENT_ID=your_google_id_here
GOOGLE_CLIENT_SECRET=your_google_secret_here